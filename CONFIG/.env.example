# ============================================================================
# Kolrose Limited - Environment Configuration Template
# Suite 10, Bataiya Plaza, Area 2 Garki, Opposite FCDA, Abuja, FCT, Nigeria
# ============================================================================
# Copy to .env: cp .env.example .env
# Get free API key: https://openrouter.ai/keys

# ============================================================================
# 🔗 API CONFIGURATION (Required)
# ============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.0-flash-001
MAX_OUTPUT_TOKENS=500
LLM_TEMPERATURE=0.0
LLM_REQUEST_TIMEOUT=30
LLM_MAX_RETRIES=3

# ============================================================================
# 🤖 EMBEDDING CONFIGURATION
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_NORMALIZE=true

# ============================================================================
# 💾 VECTOR DATABASE CONFIGURATION
# ============================================================================
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION_NAME=kolrose_policies_v2
CHROMA_DISTANCE_METRIC=cosine

# ============================================================================
# 📚 POLICY DOCUMENTS
# ============================================================================
POLICIES_PATH=./policies

# ============================================================================
# 🔍 RAG CONFIGURATION
# ============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_K=20
FINAL_K=5
MMR_LAMBDA=0.7
ENABLE_RERANK=true
ENABLE_HYBRID_SEARCH=false

# ============================================================================
# 🛡️ GUARDRAIL CONFIGURATION
# ============================================================================
ENABLE_GUARDRAILS=true
SENSITIVE_TOPICS_ENABLED=true
CITATION_REQUIRED=true
MAX_RESPONSE_CHARS=2000
MAX_SENTENCES=10

# ============================================================================
# 🏢 COMPANY INFORMATION
# ============================================================================
COMPANY_NAME=Kolrose Limited
COMPANY_ADDRESS=Suite 10, Bataiya Plaza, Area 2 Garki, Opposite FCDA, Abuja, FCT, Nigeria
COMPANY_WEBSITE=https://kolroselimited.com.ng
COMPANY_EMAIL_HR=hr@kolroselimited.com.ng
COMPANY_EMAIL_COMPLIANCE=compliance@kolroselimited.com.ng
COMPANY_EMAIL_SECURITY=security@kolroselimited.com.ng
COMPANY_HOTLINE_WHISTLEBLOWER=0800-KOLROSE
COMPANY_HOTLINE_IT_SECURITY=0800-KOL-ITSEC

# ============================================================================
# ⚙️ APPLICATION CONFIGURATION
# ============================================================================
APP_ENV=development
LOG_LEVEL=INFO
STREAMLIT_PORT=8501
FASTAPI_PORT=8000
DEBUG=false